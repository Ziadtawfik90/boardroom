# Boardroom Server
PORT=3101
HOST=0.0.0.0

# Auth
ADMIN_API_KEY=change-me-admin-key
ASUS_API_KEY=change-me-asus-key
WATER_API_KEY=change-me-water-key
STEAM_API_KEY=change-me-steam-key
JWT_SECRET=change-me-jwt-secret-at-least-64-chars

# Claude API (for agent responses)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenRouter (for Oracle/Sage advisors)
OPENROUTER_API_KEY=your-openrouter-api-key
ENABLE_ADVISORS=true

# NATS — Fleet Task Distribution
NATS_URL=nats://localhost:4222
NATS_AUTH_TOKEN=generate-with-openssl-rand-hex-32
NATS_ENABLED=true

# --- Executor-specific env vars ---
# AGENT_ID=asus
# AGENT_KEY=change-me-asus-key
# SERVER_URL=ws://localhost:3101/ws

# NATS (executor)
# FLEET_NATS_URL=nats://localhost:4222
# FLEET_NATS_TOKEN=same-token-as-server
# FLEET_NATS_ENABLED=true

# FileSync (remote workers only — not needed on ASUS)
# FLEET_IS_HUB=true                    # Set on ASUS only
# FLEET_SYNC_ROOT=/mnt/c/fleet-work    # Local workspace on WATER/STEAM
# FLEET_HUB_SSH=pc1                    # SSH alias for ASUS
# FLEET_HUB_PATH_PREFIX=/mnt/d/AI/     # ASUS path prefix
# FLEET_SYNC_RETRIES=3
# FLEET_SYNC_TIMEOUT=30
# FLEET_MAX_TASKS=3
