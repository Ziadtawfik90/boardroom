# Executor Agent Configuration
# Copy to .env and fill in values

# Agent identity: asus | water | steam
AGENT_ID=asus

# API key for authenticating with the Boardroom server
AGENT_KEY=changeme

# Boardroom server WebSocket URL
SERVER_URL=ws://localhost:3100/ws

# Agent display name (optional, defaults to AGENT_ID uppercase)
AGENT_NAME=

# Agent role description (optional)
AGENT_ROLE=
