{
  "name": "boardroom",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:server": "npm -w packages/server run dev",
    "dev:web": "npm -w packages/web run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build": "npm -w packages/shared run build && npm -w packages/server run build && npm -w packages/web run build",
    "build:executor": "npm -w packages/executor run build",
    "start:server": "npm -w packages/server run start",
    "start:executor": "npm -w packages/executor run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
